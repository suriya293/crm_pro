{
  "name": "CRM Settings",
  "doctype": "DocType",
  "module": "CRM Pro",
  "issingle": 1,
  "fields": [
    {
      "fieldname": "company_name",
      "fieldtype": "Data",
      "label": "Company Name",
      "default": "Precision CRM"
    },
    {
      "fieldname": "default_pipeline",
      "fieldtype": "Link",
      "options": "CRM Pipeline",
      "label": "Default Pipeline"
    },
    {
      "fieldname": "enable_ai_suggestions",
      "fieldtype": "Check",
      "label": "Enable AI Suggestions",
      "default": 1
    },
    {
      "fieldname": "enable_whatsapp_integration",
      "fieldtype": "Check",
      "label": "Enable WhatsApp Integration",
      "default": 0
    },
    {
      "fieldname": "whatsapp_access_token",
      "fieldtype": "Password",
      "label": "WhatsApp Access Token"
    },
    {
      "fieldname": "whatsapp_phone_number_id",
      "fieldtype": "Data",
      "label": "WhatsApp Phone Number ID"
    },
    {
      "fieldname": "facebook_access_token",
      "fieldtype": "Password",
      "label": "Facebook Access Token"
    },
    {
      "fieldname": "facebook_webhook_verify_token",
      "fieldtype": "Data",
      "label": "Facebook Webhook Verify Token"
    },
    {
      "fieldname": "facebook_app_secret",
      "fieldtype": "Password",
      "label": "Facebook App Secret"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1
    }
  ]
}
