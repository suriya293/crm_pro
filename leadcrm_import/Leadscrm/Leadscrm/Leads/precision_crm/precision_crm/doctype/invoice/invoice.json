{
  "doctype": "Invoice",
  "module": "Precision CRM",
  "autoname": "field:naming_series",
  "naming_series": "INV-.YYYY.-#####",
  "fields": [
    {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Contact", "reqd": 1},
    {"fieldname": "posting_date", "fieldtype": "Date", "label": "Posting Date", "reqd": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nUnpaid\nPaid\nOverdue\nCancelled", "default": "Draft"},
    {"fieldname": "grand_total", "fieldtype": "Currency", "label": "Grand Total"},
    {"fieldname": "owner", "fieldtype": "Link", "label": "Owner", "options": "User"},
    {"fieldname": "assigned_to", "fieldtype": "Link", "label": "Assigned To", "options": "User"},
    {"fieldname": "created_by", "fieldtype": "Link", "label": "Created By", "options": "User"},
    {"fieldname": "modified_by", "fieldtype": "Link", "label": "Modified By", "options": "User"},
    {"fieldname": "creation", "fieldtype": "Datetime", "label": "Creation"},
    {"fieldname": "modified", "fieldtype": "Datetime", "label": "Modified"},
    {"fieldname": "docstatus", "fieldtype": "Select", "label": "Docstatus", "options": "0\n1\n2"},
    {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company"},
    {"fieldname": "territory", "fieldtype": "Link", "label": "Territory", "options": "Territory"},
    {"fieldname": "team", "fieldtype": "Link", "label": "Team", "options": "Team"}
  ],
  "indexes": [{"fields": ["customer"]}, {"fields": ["status"]}],
  "workflow": "Invoice Workflow"
}
