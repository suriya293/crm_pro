{
  "doctype": "Lead",
  "module": "Precision CRM",
  "autoname": "field:naming_series",
  "naming_series": "LEAD-.YYYY.-#####",
  "fields": [
    {"fieldname": "lead_name", "fieldtype": "Data", "label": "Lead Name", "reqd": 1},
    {"fieldname": "lead_source", "fieldtype": "Select", "label": "Lead Source", "options": "Website\nReferral\nAdvertisement\nOther"},
    {"fieldname": "mobile_no", "fieldtype": "Data", "label": "Mobile Number", "reqd": 1},
    {"fieldname": "email", "fieldtype": "Data", "label": "Email"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "New\nAssigned\nAttempted Contact\nContacted\nInterested\nQualified\nConverted\nLost\nDuplicate", "default": "New"},
    {"fieldname": "assigned_to", "fieldtype": "Link", "label": "Assigned To", "options": "User"},
    {"fieldname": "created_at", "fieldtype": "Datetime", "label": "Created At", "default": "Now"},
    {"fieldname": "updated_at", "fieldtype": "Datetime", "label": "Updated At", "default": "Now"}
  ]
}
