{
  "doctype": "Password History",
  "module": "CRM Pro",
  "fields": [
    {"fieldname": "user", "fieldtype": "Link", "options": "User", "label": "User", "reqd": 1},
    {"fieldname": "hashed_password", "fieldtype": "Password", "label": "Hashed Password", "reqd": 1},
    {"fieldname": "creation", "fieldtype": "Datetime", "label": "Created On", "default": "Now"}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 0, "create": 0, "delete": 0},
    {"role": "User", "read": 1, "if_owner": 1}
  ]
}
