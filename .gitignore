# =========================
# SYSTEM FILES
# =========================
.cache/
.local/
.bash_history
.ipython/

# =========================
# LOGS
# =========================
logs/
*.log

# =========================
# PYTHON CACHE
# =========================
__pycache__/
*.pyc
*.pyo

# =========================
# FRAPPE / BENCH RUNTIME
# =========================
sites/*/private/
sites/*/public/
sites/*/locks/
sites/*/site_config.json
sites/common_site_config.json

# Redis / runtime files
config/pids/
*.rdb

# =========================
# BENCH GENERATED FILES
# =========================
patches.txt
imports.txt
cookies.txt
ratelimit_refs.txt

# =========================
# IMPORTANT: APPS SHOULD NOT BE TRACKED
# =========================
apps/frappe/
apps/*/

# If you have custom apps, ignore only frappe if needed:
# apps/frappe/
